{
  "name": "sql-ml-cli",
  "version": "0.5.0",
  "description": "CLI tool to analyze SQL files using ML-based query performance prediction",
  "main": "dist/index.js",
  "bin": {
    "sql-ml": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "analyze": "tsx src/index.ts analyze",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'src/__tests__/**'",
    "test:e2e": "vitest run src/__tests__/e2e-pipeline.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "opencode:compile": "node scripts/opencode-compile.mjs"
  },
  "keywords": [
    "sql",
    "ml",
    "cli",
    "performance",
    "analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "long": "^5.2.4",
    "mysql2": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
