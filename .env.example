# sql-ml-cli Database Connection Configuration
# Copy this file to .env and fill in your values.

# Database engine: mysql | mariadb | postgresql | sqlite
SQLML_ENGINE=mysql

# Connection settings
SQLML_HOST=localhost
SQLML_PORT=3306
SQLML_USER=
SQLML_PASSWORD=
SQLML_DATABASE=

# Optional: SSL connection
SQLML_SSL=false

# Optional: Timeout settings (in milliseconds)
SQLML_CONNECT_TIMEOUT=5000
SQLML_QUERY_TIMEOUT=10000
